{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Workbench App",
  "version": "0.1.2",
  "identifier": "local.workbench.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Workbench App",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 680
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyNUE2RDhCRUJCQTU2RQpSV1J1cGJ1KzJLWWxCRnFhZkhhaUR0a3FzdzVJanFCb0E5M1lyK25uWTE4WTQ4bnluQlBtOTlKOQo=",
      "endpoints": [
        "https://github.com/cuber-hyk/Workbench/releases/latest/download/latest.json"
      ]
    }
  }
}
